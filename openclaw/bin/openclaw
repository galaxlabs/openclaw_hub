#!/usr/bin/env python3
import sys
from datetime import datetime
from pathlib import Path

# Make repo root importable so "import openclaw..." works when running as a script
ROOT = Path(__file__).resolve().parents[2]
sys.path.insert(0, str(ROOT))

TEMPLATE = ROOT / "templates" / "job.md"
OUTDIR = ROOT / "05_job_hunt"
PROMPT_FILE = ROOT / "openclaw" / "prompts" / "job_analysis.txt"

def slug(s: str) -> str:
    s = (s or "").strip().lower()
    keep = []
    for ch in s:
        if ch.isalnum():
            keep.append(ch)
        elif ch in [" ", "-", "_"]:
            keep.append("-")
    out = "".join(keep)
    while "--" in out:
        out = out.replace("--", "-")
    return out.strip("-")

def die(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)

def cmd_job(company: str, role: str, url: str) -> None:
    today = datetime.now().strftime("%Y-%m-%d")

    if not TEMPLATE.exists():
        die(f"Missing template: {TEMPLATE}")
    OUTDIR.mkdir(parents=True, exist_ok=True)

    filename = f"{today}-{slug(company)}-{slug(role)}.md"
    outpath = OUTDIR / filename

    if outpath.exists():
        die(f"File already exists: {outpath.name}")

    body = TEMPLATE.read_text(encoding="utf-8").lstrip()

    header = "\n".join([
        "---",
        f"title: \"Job - {company} - {role}\"",
        f"date: \"{today}\"",
        f"source: \"{url}\"",
        "tags: [job, linkedin]",
        "---",
        "",
        "## Job summary",
        f"- Company: {company}",
        f"- Role: {role}",
        "- Location: Not mentioned",
        "- Remote/Onsite: Not mentioned",
        "- Salary: Not mentioned",
        "",
        "## Requirements (copy)",
        "",
        "## My match",
        "- Strengths:",
        "- Gaps:",
        "",
        "## Draft message/email (manual send only)",
        "",
        "## Status",
        "- Saved",
        "",
    ]) + "\n"

    outpath.write_text(header + body, encoding="utf-8")
    print(f"Created: {outpath.relative_to(ROOT)}")

def cmd_analyze(job_file: str, model: str = "llama3.2:1b") -> None:
    try:
        from openclaw.ollama_client import ollama_generate
    except Exception as e:
        die(f"Cannot import Ollama client. Error: {e}")

    p = Path(job_file)
    if not p.is_absolute():
        p = (ROOT / job_file).resolve()

    if not p.exists():
        die(f"Job file not found: {p}")

    if not PROMPT_FILE.exists():
        die(f"Missing prompt file: {PROMPT_FILE}")

    job_text = p.read_text(encoding="utf-8")
    prompt_rules = PROMPT_FILE.read_text(encoding="utf-8")

    user_prompt = (
        f"{prompt_rules}\n\n"
        "JOB LINK AND TEXT (raw):\n"
        "-----------------------\n"
        f"{job_text}\n\n"
        "Now produce the OUTPUT format requested above.\n"
        "End your answer with:\n</FINAL>\n"
    )

    result = ollama_generate(model=model, user_prompt=user_prompt)

    stamp = datetime.now().strftime("%Y-%m-%d %H:%M")
    append_block = (
        "\n\n## AI Analysis\n"
        f"_Generated: {stamp}_\n\n"
        f"{result}\n"
    )
    p.write_text(job_text.rstrip() + append_block, encoding="utf-8")
    print(f"Updated: {p.relative_to(ROOT)} (AI Analysis appended)")

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage:")
        print("  openclaw job \"Company\" \"Role\" \"LinkedIn URL\"")
        print("  openclaw analyze <path/to/job.md> [model]")
        sys.exit(0)

    cmd = sys.argv[1]

    if cmd == "job":
        if len(sys.argv) != 5:
            die("Expected: openclaw job \"Company\" \"Role\" \"LinkedIn URL\"")
        cmd_job(sys.argv[2], sys.argv[3], sys.argv[4])
        return

    if cmd == "analyze":
        if len(sys.argv) not in (3, 4):
            die("Expected: openclaw analyze <job_file.md> [model]")
        model = sys.argv[3] if len(sys.argv) == 4 else "llama3.2:1b"
        cmd_analyze(sys.argv[2], model=model)
        return

    die("Unknown command. Use --help.")

if __name__ == "__main__":
    main()
